FROM node:24-alpine@sha256:a0b9bf06e4e6193cf7a0f58816cc935ff8c2a908f81e6f1a95432d679c54fbfd AS base
RUN npm install -g pnpm@10.33.4

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY packages/extension-web-sdk/package.json ./packages/extension-web-sdk/
RUN pnpm install --frozen-lockfile

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/packages/extension-web-sdk/node_modules ./packages/extension-web-sdk/node_modules
COPY . .
ARG PUBLIC_API_URL=""
ARG PUBLIC_APP_VERSION="0.1.0"
# Build-time UI feature flags (empty → off; see apps/web/src/lib/featureFlags.ts)
ARG PUBLIC_ENABLE_NETWORK_DEVICES_IN_LIST=""
ENV PUBLIC_API_URL=${PUBLIC_API_URL}
ENV PUBLIC_APP_VERSION=${PUBLIC_APP_VERSION}
ENV PUBLIC_ENABLE_NETWORK_DEVICES_IN_LIST=${PUBLIC_ENABLE_NETWORK_DEVICES_IN_LIST}
RUN pnpm --filter @breeze/web build
# Create a self-contained deployment (resolves pnpm symlinks).
# pnpm 10's deploy command requires workspace deps be declared injected.
# TODO: declare @breeze/shared (and other workspace deps) as injected in
# apps/web/package.json and drop --legacy. See pnpm v10 release notes.
RUN pnpm --filter @breeze/web deploy --legacy --prod /deployed

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOST=0.0.0.0

# CVE-2026-45447: pinned base ships libcrypto3/libssl3 3.5.6; drop once the
# node:24-alpine digest is refreshed past 3.5.7.
# CVE-2026-12151: the base image's bundled npm vendors a vulnerable undici; the
# runtime entrypoint is `node`, not npm, so remove npm/npx from the runner.
RUN apk upgrade --no-cache libcrypto3 libssl3 && \
    rm -rf /usr/local/lib/node_modules/npm /usr/local/bin/npm /usr/local/bin/npx

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 astro

# Copy the self-contained deployment (flat node_modules, no symlinks)
COPY --from=builder --chown=astro:nodejs /deployed/node_modules ./node_modules
COPY --from=builder --chown=astro:nodejs /deployed/dist ./dist
COPY --from=builder --chown=astro:nodejs /deployed/package.json ./

USER astro

EXPOSE 4321
CMD ["node", "./dist/server/entry.mjs"]
