{
  "name": "@breeze/e2e-tests",
  "version": "2.0.0",
  "description": "End-to-end tests for Breeze RMM — Playwright Test (TypeScript) suite, data-testid based",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:report": "playwright show-report",
    "doc-verify": "tsx doc-verify/cli.ts",
    "doc-verify:extract": "tsx doc-verify/cli.ts extract",
    "doc-verify:run": "tsx doc-verify/cli.ts run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "playwright": "^1.58.2",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
