{
  "name": "@breeze/e2e-tests",
  "version": "2.0.0",
  "description": "End-to-end tests for Breeze RMM — Playwright Test (TypeScript) suite, data-testid based",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:report": "playwright show-report",
    "doc-verify": "tsx doc-verify/cli.ts",
    "doc-verify:extract": "tsx doc-verify/cli.ts extract",
    "doc-verify:run": "tsx doc-verify/cli.ts run",
    "monitor": "tsx live-signup/monitor.ts",
    "stage:runtime-extension-fixture": "tsx fixtures/runtime-extension/stage.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "werift": "^0.23.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
