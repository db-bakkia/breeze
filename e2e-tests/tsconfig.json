{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "fixtures/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "perf-harness/**",
    "doc-verify/**",
    "live-signup/**",
    "fixtures/runtime-extension/build/**"
  ]
}
