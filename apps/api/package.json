{
  "name": "@breeze/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "db:check-drift": "tsx scripts/check-drift.ts",
    "db:migrate": "tsx src/db/autoMigrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:e2e": "tsx src/db/seedE2eFixtures.ts",
    "check:migrations": "tsx scripts/check-migrations.ts",
    "check:migrations:nonsuperuser": "tsx scripts/check-migrations-nonsuperuser.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "oauth:gen-keys": "tsx scripts/oauth-gen-keys.ts",
    "metric-anomalies:backfill": "tsx scripts/metric-anomaly-backfill.ts",
    "metric-rollups:backfill": "tsx scripts/metric-rollup-backfill.ts",
    "breezectl": "node dist/scripts/breezectl.cjs",
    "breezectl:dev": "tsx scripts/breezectl.ts",
    "recover:stuck-agents": "tsx scripts/recover-stuck-agents.ts",
    "recover:stuck-agents:prod": "node dist/scripts/recover-stuck-agents.cjs",
    "secrets:reencrypt": "tsx ../../scripts/re-encrypt-secrets.ts",
    "start": "node dist/index.cjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:docker": "pnpm test:docker:up && pnpm test:integration; pnpm test:docker:down",
    "test:docker:down": "docker compose -f ../../docker-compose.test.yml down -v",
    "test:docker:up": "docker compose -f ../../docker-compose.test.yml up -d --wait",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:rls": "vitest run --config vitest.config.rls.ts",
    "test:rls-coverage": "vitest run --config vitest.config.rls-coverage.ts",
    "test:request-db-role": "vitest run --config vitest.config.request-db-role.ts",
    "test:site-scope-coverage": "vitest run --config vitest.config.site-scope-coverage.ts",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@breeze/extension-api": "workspace:*",
    "@breeze/extension-sdk": "workspace:*",
    "@breeze/shared": "workspace:*",
    "@elastic/elasticsearch": "^9.3.2",
    "@fastify/busboy": "^3.2.0",
    "@googleapis/admin": "^31.0.0",
    "@googleapis/calendar": "^15.0.0",
    "@googleapis/gmail": "^17.0.0",
    "@googleapis/licensing": "^5.0.1",
    "@hono/node-server": "^2.0.10",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.9.0",
    "@network-utils/vendor-lookup": "^1.0.12",
    "@sentry/node": "^10.54.0",
    "@simplewebauthn/server": "^13.3.2",
    "@types/qrcode": "^1.5.6",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.3",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.31",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "js-yaml": "^4.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "nanoid": "^5.1.15",
    "node-stream-zip": "^1.15.0",
    "nodemailer": "^9.0.3",
    "oidc-provider": "^9",
    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "resend": "^6.12.4",
    "sanitize-html": "^2.17.6",
    "semver": "^7.8.5",
    "ssh2-sftp-client": "^11.0.0",
    "stripe": "^22.0.2",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@breeze/extension-cli": "workspace:*",
    "@types/archiver": "^7.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/oidc-provider": "^9.5.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/semver": "^7.7.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "jszip": "^3.10.1",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
