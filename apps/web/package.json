{
  "name": "@breeze/web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/compute-uninstall-sha256.ts && node --experimental-strip-types scripts/copy-monaco-assets.ts",
    "presync:scripts": "node --experimental-strip-types scripts/compute-uninstall-sha256.ts",
    "predev": "node --experimental-strip-types scripts/copy-monaco-assets.ts",
    "dev": "astro dev",
    "build": "astro build",
    "build:prod": "NODE_ENV=production pnpm run build",
    "preview": "astro preview",
    "preview:docker": "NODE_ENV=production astro preview --host 0.0.0.0 --port ${PORT:-4321}",
    "prod:docker": "pnpm run build:prod && pnpm run preview:docker",
    "csp:guard": "node --experimental-strip-types scripts/check-csp-violations.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@breeze/extension-web-sdk": "workspace:*",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.6.0",
    "@novnc/novnc": "1.7.0",
    "@sentry/astro": "^10.62.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-query": "^5.101.3",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "astro": "^7.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "d3": "^7.9.0",
    "i18next": "^26.3.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.21.0",
    "monaco-editor": "0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cytoscape": "^3.31.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
